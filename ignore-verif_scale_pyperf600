 ci/vmtest/configs/DENYLIST-6.18 |    1 +
 2 files changed, 2 insertions(+)
 create mode 100644 ci/vmtest/configs/DENYLIST-6.18

diff --git a/ci/vmtest/configs/DENYLIST b/ci/vmtest/configs/DENYLIST
index ef891b2..086ff9c 100644
--- a/ci/vmtest/configs/DENYLIST
+++ b/ci/vmtest/configs/DENYLIST
@@ -16,3 +16,4 @@ map_kptr                  # kprobe rcu_tasks_trace_postgp not available in VM ke
 test_profiler             # kretprobe do_filp_open not available in VM kernel
 sockmap_basic/sockmap udp multi channels  # flaky in CI
 bpf_cookie/perf_event # flaky, needs investigation
+verif_scale_pyperf600 # failing since LLVM 18+
diff --git a/ci/vmtest/configs/DENYLIST-6.18 b/ci/vmtest/configs/DENYLIST-6.18
new file mode 100644
