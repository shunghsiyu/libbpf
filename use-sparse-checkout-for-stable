Use sparse checkout for stable-queue.git

From: Shung-Hsi Yu <shung-hsi.yu@suse.com>

This should make stable-queue checkout slightly faster. Also, add a
check for whether the current kernel version is still maintained.

Signed-off-by: Shung-Hsi Yu <shung-hsi.yu@suse.com>
---
 .github/workflows/vmtest.yml |    8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/.github/workflows/vmtest.yml b/.github/workflows/vmtest.yml
index 3fe5a74..7c50e08 100644
--- a/.github/workflows/vmtest.yml
+++ b/.github/workflows/vmtest.yml
@@ -50,7 +50,13 @@ jobs:
       - name: Get queued stable patches
         shell: bash
         run: |
-          git clone --branch 'master' --single-branch --depth=1 'https://git.kernel.org/pub/scm/linux/kernel/git/stable/stable-queue.git' '${{ github.workspace }}/.stable-queue'
+          git clone --branch 'master' --single-branch --filter=blob:none --depth=1 --sparse 'https://git.kernel.org/pub/scm/linux/kernel/git/stable/stable-queue.git' '${{ github.workspace }}/.stable-queue'
+          cd '${{ github.workspace }}/.stable-queue'
+          if ! grep -e '^${{ inputs.kernel }}$' active_kernel_versions >/dev/null; then
+          	echo 'Stable ${{ inputs.kernel }} not actively maintained anymore, failing'
+          	exit 1
+          fi
+          git sparse-checkout set 'queue-${{ inputs.kernel }}/'
 
       - name: Apply queued stable patches
         shell: bash
