-static void
-fdls_process_tgt_prli_rsp(struct fnic_iport_s *iport,
-			  struct fc_frame_header *fchdr)
-{
-	uint32_t tgt_fcid;
-	struct fnic_tport_s *tport;
-	uint8_t *fcid;
-	uint16_t oxid;
-	struct fc_std_els_prli *prli_rsp = (struct fc_std_els_prli *)fchdr;
