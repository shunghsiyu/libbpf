- *    -> ABTS if timeout (ABTS tomeout - 2 * R_A_TOV)
- *                        <- PLOGI response
- *    -> Retry PLOGI to FFFFFC (DNS) - Number of retries from vnic.cfg
- *
- * -> SCR to FFFFFC (DNS) (SCR timeout - 2 * R_A_TOV)
- *    -> ABTS if timeout (ABTS tomeout - 2 * R_A_TOV)
- *                        <- SCR response
- *    -> Retry SCR - Number of retries 2
- *
