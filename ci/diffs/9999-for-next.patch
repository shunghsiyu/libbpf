-
-	pba_acc->acc.ba_rx_id = cpu_to_be16(FNIC_STD_GET_RX_ID(fchdr));
-	pba_acc->acc.ba_ox_id = cpu_to_be16(FNIC_STD_GET_OX_ID(fchdr));
-
-	FNIC_FCS_DBG(KERN_INFO, fnic->host, fnic->fnic_num,
